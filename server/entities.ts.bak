export const default_entities: Entities = {
  user: {
    /**
        * 创建user记录
        * @param data 不含主键的数据 (主键自动生成)
        * @returns 创建的记录或null
        */
        Create: async (data: user_without_PKs): Promise<user | null> => {
            try {
                return await prisma.user.create({
                    data: data 
                });
            } catch (error) {
                console.error(`Error creating user:`, error);
                return null;
            }
        },

    /**
        * 根据主键获取记录
        * @param args 主键参数
        * @returns 记录或null
        */
        Get: async (args: user_uniqueKey): Promise<user | null> => {
            try {
                return await prisma.user.findUnique({
                    where: { id: args.id },
                });
            } catch (error) {
                console.error(`Error getting user:`, error);
                return null;
            }
        },

    /**
        * 获取所有记录
        * @param args 可选筛选条件 (类型: filtered_user)
        * @returns 记录数组
        */
        GetAll: async (args?: filtered_user): Promise<user[]> => {
            try {
                return await prisma.user.findMany({
                    where: args as any, 
                });
            } catch (error) {
                console.error(`Error getting all user:`, error);
                return [];
            }
        },

    /**
        * 分页获取记录
        * @param pageNumber 页码 (默认 1)
        * @param pageSize 每页大小 (默认 10)
        * @param args 可选筛选条件 (类型: filtered_user)
        * @returns 分页记录数组
        */
        GetPage: async (
            pageNumber: number = 1,
            pageSize: number = 10,
            args?: filtered_user
        ): Promise<user[]> => {
            try {
                const skip = (pageNumber - 1) * pageSize;
                return await prisma.user.findMany({
                    where: args as any, 
                    skip,
                    take: pageSize,
                });
            } catch (error) {
                console.error(`Error getting paged user:`, error);
                return [];
            }
        },

    /**
        * 统计记录数
        * @param args 可选筛选条件 (类型: filtered_user)
        * @returns 记录数量
        */
        Count: async (args?: filtered_user): Promise<number> => {
            try {
                return await prisma.user.count({
                    where: args as any, 
                });
            } catch (error) {
                console.error(`Error counting user:`, error);
                return 0;
            }
        },

    /**
        * 更新记录
        * @param args 包含主键 (where) 和更新数据 (data)
        * @returns 更新后的记录或null
        */
        Update: async (args: { where: user_uniqueKey; data: user_without_PKs }): Promise<user | null> => {
            try {
                return await prisma.user.update({
                    where: { id: args.where.id },
                    data: args.data 
                });
            } catch (error) {
                console.error(`Error updating user:`, error);
                return null;
            }
        },

    /**
        * 删除记录
        * @param args 主键参数
        * @returns 删除的记录或null
        */
        Delete: async (args: user_uniqueKey): Promise<user | null> => {
            try {
                return await prisma.user.delete({
                    where: { id: args.id },
                });
            } catch (error) {
                console.error(`Error deleting user:`, error);
                return null;
            }
