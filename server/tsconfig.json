{
  "extends": "../tsconfig.server.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../dist",
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "start.ts",
    "index.ts",
    "entities.ts",
    "entity-handler.ts",
    "types.ts"
  ],
  "exclude": ["node_modules", "**/*.spec.ts"]
}