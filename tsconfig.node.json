{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* تنظيم المسارات للربط مع الأدوات */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* وضع Bundler المتقدم لدعم Next.js 16 و Rsbuild */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* معايير صارمة لجودة الكود (Linting) */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    
    /* تحسينات إضافية للتوافق مع Node.js الحديث */
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "rsbuild.config.ts", 
    "next.config.ts", 
    "postcss.config.mjs",
    "tailwind.config.ts"
  ]
}