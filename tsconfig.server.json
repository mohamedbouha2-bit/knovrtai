{
  "compilerOptions": {
    /* إعدادات الهدف والبيئة */
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ESNext"],
    "strict": true,
    
    /* إعدادات البناء والمخرجات */
    "outDir": "./dist_server",
    "rootDir": ".",
    "composite": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",

    /* التوافق والأمان */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "noImplicitAny": true,

    /* تنظيم المسارات للسيرفر */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@server/*": ["./server/*"]
    }
  },
  "include": [
    "server/**/*.ts",
    "prisma/**/*.ts" /* تضمين ملفات بريزما لاستخدام الـ Types في السيرفر */
  ],
  "exclude": [
    "node_modules",
    "pnpm_node_modules",
    "dist",
    "dist_server",
    "src",
    "app" 
  ]
}